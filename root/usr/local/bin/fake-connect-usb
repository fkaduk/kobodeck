#!/bin/sh

# cargo-culted from
# https://github.com/Michael-Bell/Kobo-Mini-Wireless-Sync/blob/master/update.sh

# unfortunately, this still requires user interaction. see a more
# complete discussion here:
# https://www.mobileread.com/forums/showthread.php?p=3467503

delay=15

echo Simulating USB cable connect
echo usb plug add >>/tmp/nickel-hardware-status
echo Waiting $delay seconds for user to hit Connect
sleep $delay
echo Simulating USB cable disconnect
echo usb plug remove >>/tmp/nickel-hardware-status
sleep 3
if ! mount | grep onboard; then
    echo disk not mounted, force-mounting
    mount /dev/mmcblk0p3 /mnt/onboard
fi
